{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
{%- enddoc -%}

<div class="cart__summary-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart__summary-item cart__original-total">
        <span class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</span>
        <span class="cart__original-total-value cart-secondary-typography">
          {{- cart.original_total_price | money -}}
        </span>
      </span>
      <div class="cart__summary-discounts">
        <ul
          class="discounts list-unstyled"
          role="list"
          aria-label="{{ 'content.discounts' | t }}"
        >
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                {{ discount.title | escape }}
              </span>
              <span class="cart__discount-value cart-secondary-typography"
                >-{{ discount.total_allocated_amount | money -}}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {% if settings.show_entry_total %}
      {%- assign entry_total_label_font_size = settings.entry_total_label_font_size | default: 24 -%}
      {%- assign entry_total_label_color = settings.entry_total_label_color | default: '#1A1A1A' -%}
      {%- assign entry_total_value_font_size = settings.entry_total_value_font_size | default: 24 -%}
      {%- assign entry_total_value_color = settings.entry_total_value_color | default: '#1A1A1A' -%}
      {%- assign entry_total_secondary_font_size = settings.entry_total_secondary_font_size | default: 16 -%}
      {%- assign entry_total_secondary_color = settings.entry_total_secondary_color | default: '#666666' -%}

      <div
        class="cart-entry-total"
        id="cart-entry-total-block"
        hidden
      >
        <div class="cart-entry-total__primary">
          <strong
            class="cart-entry-total__label"
            style="font-size: {{ entry_total_label_font_size }}px; color: {{ entry_total_label_color }};"
          >Total Entries:</strong>
          <strong
            class="cart-entry-total__value"
            id="cart-entries-total"
            data-show-ticket="{{ settings.entry_total_show_ticket }}"
            style="font-size: {{ entry_total_value_font_size }}px; color: {{ entry_total_value_color }};"
          >
            {% if settings.entry_total_show_ticket %}🎟 {% endif %}0
          </strong>
        </div>
        <div
          class="cart-entry-total__secondary"
          style="font-size: {{ entry_total_secondary_font_size }}px !important; color: {{ entry_total_secondary_color }} !important;"
        >
          Across
          <span
            id="cart-active-sweepstakes"
            style="font-size: {{ entry_total_secondary_font_size }}px !important; color: {{ entry_total_secondary_color }} !important;"
          >0</span>
          Active Giveaways
        </div>
      </div>
    {% endif %}


  </div>


  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        {% render 'cart-note' %}
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% render 'cart-discount', section_id: section.id %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart__total-container">
    <span
      class="cart__summary-item cart__total"
      role="status"
    >
      <span class="cart__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>

    </span>
    {% if settings.show_installments %}
      <span class="cart__summary-item cart__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart__summary-item tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>

</div>


<div class="cart__ctas">
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button cart__checkout-button--outline"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% endif %}
    form="cart-form"
  >
    {{ 'content.checkout' | t }}
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    border-block: 1px solid var(--color-border);
    padding-block: var(--padding-sm);
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart__summary-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  .cart__installments {
    color: var(--color-foreground);
  }


  .cart__ctas .additional-checkout-buttons,
  .cart__ctas .dynamic-checkout__content {
    display: contents;
  }

  .cart__ctas shopify-accelerated-checkout-cart {
    order: -2;
  }

  .cart__ctas .cart__checkout-button {
    order: -1;
  }

  .cart__ctas #shopify-buyer-consent {
    order: 10;
  }

  .cart__checkout-button--outline {
    background: transparent !important;
    color: #e8922f !important;
    border: 2px solid #e8922f !important;
  }

  .cart__checkout-button--outline:hover {
    background: #e8922f !important;
    color: #ffffff !important;
  }

  .cart-entry-total {
    margin-block-start: var(--margin-xs);
  }

  .cart-entry-total__primary {
    line-height: 1.3;
  }

  .cart-entry-total__label {
    font-weight: 700;
  }

  .cart-entry-total__value {
    font-weight: 800;
    margin-inline-start: 0.25rem;
  }

  .cart-entry-total__secondary {
    line-height: 1.35;
    font-weight: 400;
    margin-block-start: 0.2rem;
  }

{% endstylesheet %}
